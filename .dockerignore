# pixi environments (large, rebuilt inside Docker)
.pixi/

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Test/coverage artifacts
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Node / frontend
node_modules/
frontend/node_modules/
frontend/build/
frontend/dist/

# Editors / IDE
.vscode/
.idea/
*.swp
*.swo

# Git
.gitignore

# OS
.DS_Store
Thumbs.db

# Local secrets / env files
**/.env
**/.env.*
**/.env.example
*.credentials.json

# Docs build output
site/
docs/_build/

# Seed CSVs — these are large data files that must never be baked into the
# Docker image.  The seed step reads from a volume-mounted path (SEED_CSV_PATH)
# or the __file__-relative fallback; baking the CSV into the image causes the
# old (potentially incorrect) data to be re-seeded on every container start.
**/seed_food_processor_facilities.csv
**/geocode_backup_*.csv
